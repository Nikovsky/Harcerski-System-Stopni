{
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**",
        ".next/**"
      ]
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "outputs": []
    },
    "test": {
      "outputs": []
    },
    "test:e2e": {
      "cache": false,
      "outputs": [
        "generated/**"
      ]
    },
    "test:a11y": {
      "cache": false,
      "outputs": [
        "generated/**"
      ]
    },
    "test:perf": {
      "cache": false,
      "outputs": [
        "generated/**"
      ]
    },
    "db:generate": {
      "cache": false
    },
    "db:prepare": {
      "cache": false
    },
    "db:migrate": {
      "dependsOn": [
        "build"
      ],
      "cache": false
    },
    "db:deploy": {
      "cache": false
    },
    "db:reset": {
      "cache": false
    },
    "db:reset:force": {
      "cache": false
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "@hss/schemas#dev": {
      "dependsOn": [
        "build"
      ],
      "cache": false,
      "persistent": true
    },
    "@hss/database#build": {
      "dependsOn": [
        "db:generate"
      ],
      "cache": false,
      "outputs": [
        "dist/**"
      ]
    },
    "@hss/database#dev": {
      "dependsOn": [
        "db:prepare"
      ],
      "cache": false,
      "persistent": true
    },
    "api#dev": {
      "dependsOn": [
        "@hss/database#db:prepare",
        "^build"
      ],
      "cache": false,
      "persistent": true
    },
    "web#dev": {
      "dependsOn": [
        "@hss/database#db:prepare",
        "^build"
      ],
      "cache": false,
      "persistent": true
    }
  }
}
