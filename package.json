{
  "name": "hss",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm powershell:cls && pnpm validate:env && pnpm db:generate && pnpm schemas:build && pnpm db:build && pnpm --recursive --parallel --stream --filter api --filter web run dev",
    "start:warm": "pnpm dev",
    "start:cold": "pnpm install && pnpm stack:up && pnpm dev",
    "restart:project": "pnpm stack:down && pnpm clean && pnpm start:cold",
    "restart:dev": "pnpm clean && pnpm install && pnpm dev",
    "build": "pnpm --recursive --if-present run build",
    "analyze:bundle": "pnpm -C apps/web analyze:bundle",
    "lint": "pnpm --recursive --if-present run lint",
    "typecheck": "pnpm schemas:build && pnpm db:build && pnpm --recursive --if-present run typecheck",
    "test": "pnpm --recursive --if-present run test",
    "test:e2e": "pnpm --filter web run test:e2e",
    "test:a11y": "pnpm --filter web run test:a11y",
    "test:perf": "pnpm --filter web run test:perf",
    "test:browser:install": "pnpm -C apps/web test:browser:install",
    "validate:env": "node scripts/validate-env.mjs",
    "clean:build": "node scripts/clean.mjs --build",
    "clean:deps": "node scripts/clean.mjs --deps",
    "clean": "pnpm clean:build && pnpm clean:deps",
    "stack:up": "node scripts/infra.mjs --up",
    "stack:down": "node scripts/infra.mjs --down",
    "stack:stop": "node scripts/infra.mjs --stop",
    "stack:start": "node scripts/infra.mjs --start",
    "stack:status": "node scripts/infra.mjs --status",
    "stack:is-running": "node scripts/infra.mjs --is-running",
    "delete:project": "pnpm stack:down && pnpm clean",
    "az5": "pnpm delete:project",
    "db:build": "pnpm --filter @hss/database run build",
    "db:generate": "pnpm --filter @hss/database run db:generate",
    "db:prepare": "pnpm --filter @hss/database run db:prepare",
    "db:migrate": "pnpm --filter @hss/database run db:migrate",
    "db:deploy": "pnpm --filter @hss/database run db:deploy",
    "db:studio": "pnpm --filter @hss/database run db:studio",
    "db:reset": "pnpm --filter @hss/database run db:reset",
    "db:reset:force": "pnpm --filter @hss/database run db:reset:force",
    "schemas:build": "pnpm --filter @hss/schemas run build",
    "prisma:new:migration": "(pnpm stack:is-running || pnpm stack:up) && pnpm -C packages/database exec -- prisma migrate dev",
    "prisma:del:migration": "(pnpm stack:is-running || pnpm stack:up) &&pnpm -C packages/database exec -- prisma migrate reset && pnpm powershell:clean:prisma:migration",
    "prisma:seed": "pnpm -C packages/database exec -- tsx prisma/seed.ts",
    "powershell:clean:prisma:migration": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"if (Test-Path 'packages/database/prisma/migrations') { Remove-Item -Recurse -Force 'packages/database/prisma/migrations' }\"",
    "powershell:cls": "powershell -NoProfile -ExecutionPolicy Bypass -Command Clear-Host"
  },
  "authors": [
    "Kacper BO$ <https://github.com/bos-8>",
    "Nikolas Jerzy Feduniewicz <https://github.com/Nikovsky>"
  ],
  "license": "AGPL-3.0-only",
  "packageManager": "pnpm@11.8.0"
}
