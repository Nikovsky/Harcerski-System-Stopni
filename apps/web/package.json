  "scripts": {
    "dev": "cross-env NODE_EXTRA_CA_CERTS=..\\..\\docker\\certs\\rootCA.pem next dev --webpack",
    "build": "next build",
    "analyze:bundle": "node ./scripts/analyze-commission-bundle.mjs",
    "start": "next start",
    "lint": "eslint . --ignore-pattern generated --ignore-pattern .next",
